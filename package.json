{
  "name": "myclawteam",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @myclawteam/shared && npm run build --workspace @myclawteam/api && npm run build --workspace @myclawteam/web",
    "build:api": "npm run build --workspace @myclawteam/api",
    "build:web": "npm run build --workspace @myclawteam/web",
    "dev:api": "npm run dev --workspace @myclawteam/api",
    "dev:web": "npm run dev --workspace @myclawteam/web",
    "start": "npm run start --workspace @myclawteam/api"
  },
  "engines": {
    "node": ">=20"
  }
}
